{
  "name": "digitaalinen-tuotepassi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "playwright test",
    "test:smoke": "WORKER_URL=https://api.digitaalinentuotepassi.tulkintatila.fi playwright test",
    "db:create": "wrangler d1 create digitaalinen_tuotepassi",
    "db:init": "wrangler d1 execute digitaalinen_tuotepassi --local --file=./schema_full.sql",
    "db:init:remote": "wrangler d1 execute digitaalinen_tuotepassi --remote --file=./schema_full.sql"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "wrangler": "^4.0.0"
  }
}
